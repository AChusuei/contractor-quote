# HubSpot CRM
VITE_HUBSPOT_PORTAL_ID=your_portal_id_here
VITE_HUBSPOT_FORM_ID=your_form_id_here

# Supabase (photo uploads)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
