# White-label branding
VITE_CQ_CONTRACTOR_NAME=Your Company Name
# Localhost fallback: contractor slug used when no sessionStorage cq_super_contractor_id is set
VITE_CQ_CONTRACTOR_SLUG=central-cabinets

# Address autocomplete
VITE_CQ_ADDRESS_PROVIDER=mapbox
VITE_CQ_MAPBOX_API_KEY=your_mapbox_public_token_here

# Google Places (if switching provider to google)
# VITE_CQ_GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Google Appointment Schedule embed URL (from Google Calendar → Appointment Schedule → Booking page)
VITE_CQ_GOOGLE_APPOINTMENT_URL=https://calendar.google.com/calendar/appointments/schedules/your_schedule_id_here

# Calendar scheduling provider: 'google' or unset (no live calendar)
# VITE_CQ_CALENDAR_PROVIDER=google
# VITE_GOOGLE_CALENDAR_ACCESS_TOKEN=your_oauth_access_token_here

# Photo storage provider: 'local' (IndexedDB, default in dev) or future cloud provider
VITE_CQ_STORAGE_PROVIDER=local

# Supabase (photo uploads — future cloud provider)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Contractor phone number (shown on confirmation screen)
VITE_CQ_CONTRACTOR_PHONE=(555) 123-4567

# Cloudflare Turnstile (bot protection on intake form)
# Get keys from https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
# Backend secret key is set via: wrangler secret put TURNSTILE_SECRET_KEY

# Admin portal authentication (Clerk)
# Get your publishable key from https://dashboard.clerk.com
# When not set, /admin routes are accessible without authentication (dev only)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Paddle billing (client-side token for Paddle.js, analogous to a publishable key)
# Get from Paddle dashboard → Developer Tools → Authentication
VITE_PADDLE_CLIENT_TOKEN=test_your_paddle_client_token_here

# Billing feature flag — set to "true" to enable billing UI and API endpoints
# Requires BILLING_ENABLED=true in apps/api wrangler.toml (or .dev.vars) as well
VITE_CQ_BILLING_ENABLED=false
