# apps/api local dev environment
# Copy to .env and fill in values. Never commit .env.

# Set via `wrangler secret put` for deployed workers.
# For local dev, wrangler reads from .dev.vars (not this file).
# See: https://developers.cloudflare.com/workers/configuration/secrets/
TOKEN_SIGNING_SECRET=your_hmac_signing_secret_here
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Platform admin emails (comma-separated) — users who can manage all contractors
# Also set in wrangler.toml [vars] for local dev
PLATFORM_ADMIN_EMAILS=admin@example.com

# Clerk JWKS URL for JWT signature verification (required in production)
# Find your Clerk domain in Clerk dashboard → API Keys → Advanced
# e.g. https://<your-clerk-domain>/.well-known/jwks.json
# Set via: wrangler secret put CLERK_JWKS_URL
# When not set, JWT signature verification is skipped in development only.
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
