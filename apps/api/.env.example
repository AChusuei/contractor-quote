# apps/api local dev environment
# Copy to .env and fill in values. Never commit .env.

# Set via `wrangler secret put` for deployed workers.
# For local dev, wrangler reads from .dev.vars (not this file).
# See: https://developers.cloudflare.com/workers/configuration/secrets/
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here
TOKEN_SIGNING_SECRET=your_hmac_signing_secret_here
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Platform admin emails (comma-separated) — users who can manage all contractors
# Also set in wrangler.toml [vars] for local dev
PLATFORM_ADMIN_EMAILS=admin@example.com
