{
  "name": "@contractor-quote/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "wrangler dev --local",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "node scripts/generate-test-schema.js",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply cq-dev --local",
    "migrate:remote": "wrangler d1 migrations apply cq-dev --remote",
    "db:reset:local": "wrangler d1 execute cq-dev --local --file=scripts/reset-local.sql && npm run migrate:local"
  },
  "dependencies": {
    "@contractor-quote/types": "*",
    "hono": "^4.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "~5.6.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.78.0"
  }
}
